FROM node:20-alpine

WORKDIR /app

# Install deps first (better layer caching)
COPY package*.json ./
RUN npm ci --omit=dev

# Copy source
COPY . .

# Generate Prisma client (needed since it's generated based on your schema)
RUN npx prisma generate

# Run as a non-root user (security best practice)
RUN addgroup -S appgroup && adduser -S appuser -G appgroup
USER appuser

EXPOSE 7004

# Change "server.js" to match your actual entry file (e.g. index.js, app.js)
CMD ["node", "server.js"]