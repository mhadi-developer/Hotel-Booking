# ---- Stage 1: Build ----
FROM node:20-alpine AS build

WORKDIR /app

# Install deps first (better layer caching)
COPY package*.json ./
RUN npm ci

# Copy source and build
COPY . .
RUN npm run build

# ---- Stage 2: Serve static build ----
FROM node:20-alpine

WORKDIR /app

# 'serve' is a tiny static file server, good for SPAs (handles client-side routing with -s)
RUN npm install -g serve

COPY --from=build /app/dist ./dist

EXPOSE 5173

CMD ["serve", "-s", "dist", "-l", "5173"]